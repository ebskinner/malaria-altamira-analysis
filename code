// Filter ERA5 collection by years of interest
var era5 = ee.ImageCollection('ECMWF/ERA5/MONTHLY')
  .filter(ee.Filter.calendarRange(2005,2021,'year'));

// Calculate annual means  
var annualTemp = era5.select('mean_2m_air_temperature').mean();
var annualPrecip = era5.select('total_precipitation').sum();

// Load and filter MapBiomas land cover 
var mapbiomas = ee.ImageCollection('projects/mapbiomas-workspace/public/collection7_1/mapbiomas_collection71_integration_v1')
  .filter(ee.Filter.calendarRange(2005,2021,'year'))
  .select('classification');

// Calculate distance to deforestation per cluster
var distDeforest = mapbiomas.map(function(image){
  var year = image.get('year');
  var deforested = image.eq(3);
  var dist = deforested.fastDistanceTransform(50000, 'kilometers');
  return dist.set('year', year);
});

// Calculate forest edge per cluster
var forestEdge = mapbiomas.map(function(image){
  var year = image.get('year');
  var forest = image.eq(3);
  var edge = forest.reduceNeighborhood({
    reducer: ee.Reducer.max(), 
    kernel: ee.Kernel.square(1),
  }).subtract(forest);
  var edgeLength = edge.multiply(ee.Image.pixelArea()).divide(1000);
  return edgeLength.set('year', year);  
});

// Extract values per cluster per year
var clusters = ee.FeatureCollection('ebskinn/assets/clusters.shp');

var clusterValues = clusters.map(function(cluster){
  var clusterTemp = annualTemp.reduceRegions({
    collection: ee.FeatureCollection([cluster]),
    reducer: ee.Reducer.mean(), 
    scale: 1000,
  });
  
  var clusterPrecip = annualPrecip.reduceRegions({
    collection: ee.FeatureCollection([cluster]),
    reducer: ee.Reducer.mean(), 
    scale: 1000,
  });
  
  var clusterDeforest = distDeforest.map(function(image){
    return image.reduceRegions({
      collection: ee.FeatureCollection([cluster]),
      reducer: ee.Reducer.mean(), 
      scale: 1000,
    }).first().set('year', image.get('year'));
  });
  
  var clusterEdge = forestEdge.map(function(image){
    return image.reduceRegions({
      collection: ee.FeatureCollection([cluster]),
      reducer: ee.Reducer.sum(), 
      scale: 30,
    }).first().set('year', image.get('year'));
  });
  
  // Combine into one feature per cluster
  return ee.Feature(cluster.first())
    .set('tempVals',clusterTemp.aggregate_array('mean'))
    .set('precipVals',clusterPrecip.aggregate_array('mean'))
    .set('deforestDist',clusterDeforest.aggregate_array('mean'))  
    .set('edgeLength',clusterEdge.aggregate_array('sum'));
});

// Export results
Export.table.toDrive({
  collection: clusterValues, 
  description: 'cluster_environ_data',
  fileFormat: 'CSV'
});

